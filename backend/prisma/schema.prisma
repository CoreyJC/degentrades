generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String
  username      String         @unique
  walletAddress String?        @unique
  createdAt     DateTime       @default(now())
  portfolio     Portfolio?
  holdings      Holding[]
  transactions  Transaction[]
  seasonRewards SeasonReward[]
}

model Season {
  id        String         @id @default(cuid())
  number    Int            @unique
  startedAt DateTime       @default(now())
  endedAt   DateTime?
  status    String         @default("active") // active | completed
  rewards   SeasonReward[]
}

model SeasonReward {
  id       String  @id @default(cuid())
  seasonId String
  userId   String
  rank     Int
  bonusSol Float
  season   Season  @relation(fields: [seasonId], references: [id])
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Portfolio {
  id          String   @id @default(cuid())
  userId      String   @unique
  solBalance  Float    @default(100.0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Coin {
  id             String        @id @default(cuid())
  name           String
  ticker         String        @unique
  currentPrice   Float
  marketCap      Float         @default(0)
  totalSupply    Int           @default(1000000000)
  rugProbability Float         @default(0.005)
  isActive       Boolean       @default(true)
  migrated       Boolean       @default(false)
  migratedAt     DateTime?
  createdAt      DateTime      @default(now())
  holdings       Holding[]
  transactions   Transaction[]
}

model Holding {
  id           String   @id @default(cuid())
  userId       String
  coinId       String
  amount       Float    @default(0)
  avgBuyPrice  Float    @default(0)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  coin         Coin     @relation(fields: [coinId], references: [id])

  @@unique([userId, coinId])
}

model DistributionEpoch {
  id             String               @id @default(cuid())
  totalSol       Float
  distributedSol Float                @default(0)
  startedAt      DateTime             @default(now())
  endsAt         DateTime
  status         String               @default("active") // active | completed | cancelled
  payouts        DistributionPayout[]
}

model DistributionPayout {
  id        String            @id @default(cuid())
  epochId   String
  wallet    String
  amountSol Float
  txSig     String?
  status    String            @default("pending") // pending | confirmed | failed
  createdAt DateTime          @default(now())
  epoch     DistributionEpoch @relation(fields: [epochId], references: [id])
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  coinId      String
  type        String   // BUY or SELL
  amount      Float
  price       Float
  solSpent    Float
  avgBuyPrice Float?   // avg buy price at time of sell (for P&L calc)
  pnlPct      Float?   // % gain/loss on this sell
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  coin        Coin     @relation(fields: [coinId], references: [id])
}
